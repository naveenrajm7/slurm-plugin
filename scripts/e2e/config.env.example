# Local e2e configuration — COPY to config.env and fill in your values.
# config.env is gitignored; never commit real hostnames, IPs, or usernames.
#
#   cp scripts/e2e/config.env.example scripts/e2e/config.env

# Jenkins (local hpi:run)
JENKINS_URL=http://localhost:8080/jenkins

# Slurm cluster SSH (for squeue/sacct and WSL agent tunnel)
SLURM_SSH_HOST=YOUR_USER@YOUR_SLURM_CONTROLLER
SLURM_SSH_OPTS="-o BatchMode=yes -o ConnectTimeout=10"

# Slurm account for scontrol token / squeue (optional; defaults to SSH login user)
# SLURM_USER=YOUR_SLURM_USER

# WSL reverse tunnel: remote port -> local Jenkins (agents only; UI stays on :8080)
TUNNEL_REMOTE_PORT=5000
TUNNEL_LOCAL_PORT=8080
TUNNEL_REMOTE_BIND=127.0.0.1

# Slurm cloud settings (must match Jenkins cloud configuration)
SLURM_CLOUD_NAME=your-slurm-cloud
SLURM_REST_URL=http://YOUR_SLURM_CONTROLLER:6820
SLURM_JENKINS_AGENT_URL=http://localhost:5000/jenkins/
SLURM_CREDENTIALS_ID=slurm-jwt-token

# E2E Jenkins jobs (folder/job name without 'job/' prefix)
E2E_FOLDER=your-jenkins-folder
E2E_JOB_TEMPLATE_TEST=template-test
E2E_JOB_DECLARATIVE_JSON=dec-json-test

# Static cloud template (label + workdir on compute nodes)
E2E_TEMPLATE_LABEL=your-agent-label
E2E_TEMPLATE_WORKDIR=/tmp/jenkins

# Slurm e2e cluster resources (created by prepare-slurm-cluster.sh via sudo)
E2E_PARTITION=jenkins-e2e
E2E_FEATURE=jenkins-e2e
E2E_RESERVATION=jenkins-e2e
E2E_RESERVATION_NODE=YOUR_RESERVATION_NODE

# Optional: job-options coverage test (setup-options-coverage.ps1)
# E2E_OPTIONS_LABEL=options-e2e
# E2E_SLURM_ACCOUNT=your-slurm-account
# E2E_REQUIRED_NODES=node1
# E2E_EXCLUDED_NODES=node2,node3

# Optional: native agent e2e (setup-native-agent.ps1)
# E2E_NATIVE_LABEL=native-e2e

# Native agent launch (without Pyxis) — paths on compute nodes
E2E_NATIVE_AGENT_JAR=/opt/jenkins/agent.jar
E2E_NATIVE_JAVA_PATH=/opt/jenkins/jdk-17/bin/java
E2E_NATIVE_AGENT_JAR_DIR=/opt/jenkins

# Container images for declarative JSON tests (paths on cluster; used in examples only)
E2E_CPU_CONTAINER_IMAGE=/path/to/jenkins-inbound-agent.sqsh
E2E_GPU_CONTAINER_IMAGE=/path/to/rocm-jenkins.sqsh
