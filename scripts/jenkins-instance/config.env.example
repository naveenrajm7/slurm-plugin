# Dedicated Jenkins instance harness — COPY to config.env and fill in your values.
# config.env is gitignored; never commit hostnames, passwords, or tokens.
#
#   cp scripts/jenkins-instance/config.env.example scripts/jenkins-instance/config.env

# Remote host where Docker Jenkins runs (SSH target for deploy scripts)
JENKINS_SSH_HOST=YOUR_USER@YOUR_JENKINS_HOST
JENKINS_SSH_OPTS="-o BatchMode=yes -o ConnectTimeout=10"
JENKINS_REMOTE_DIR=/tmp/jenkins-instance

# Jenkins HTTP (browser + REST scripts on your machine)
JENKINS_HTTP_PORT=8282
JENKINS_HOSTNAME=YOUR_JENKINS_HOST
JENKINS_URL=http://YOUR_JENKINS_HOST:8282

# URL Slurm agents use (direct reachability — no SSH tunnel)
JENKINS_AGENT_URL=http://YOUR_JENKINS_HOST:8282/

JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=CHANGE_ME

# Slurm cluster SSH (for squeue / workdir prep; often same host as JENKINS_SSH_HOST)
SLURM_SSH_HOST=YOUR_USER@YOUR_SLURM_CONTROLLER
SLURM_SSH_OPTS="-o BatchMode=yes -o ConnectTimeout=10"

# Slurm account for scontrol token (optional; defaults to SSH login user)
# SLURM_USER=YOUR_SLURM_USER

# Slurm cloud settings (applied by configure.ps1)
SLURM_CLOUD_NAME=your-slurm-cloud
SLURM_REST_URL=http://YOUR_SLURM_CONTROLLER:6820
SLURM_CREDENTIALS_ID=slurm-jwt-token
# JWT for slurmrestd — set one of:
# SLURM_JWT_TOKEN=eyJ...
# or leave unset to fetch via: scontrol token username=$USER on SLURM_SSH_HOST

# E2E Jenkins jobs (folder/job name without 'job/' prefix)
E2E_FOLDER=slurm-e2e
E2E_JOB_TEMPLATE_TEST=template-test
E2E_JOB_DECLARATIVE_JSON=dec-json-test

# Static cloud template (label + workdir on compute nodes)
E2E_TEMPLATE_LABEL=your-agent-label
E2E_TEMPLATE_PARTITION=cpu
E2E_TEMPLATE_CPUS=16
E2E_TEMPLATE_MEMORY_MB=32768
E2E_TEMPLATE_WORKDIR=/tmp/jenkins
E2E_TIME_LIMIT_MINUTES=55
E2E_RESERVATION=jenkins-e2e

# Container images for declarative JSON tests (cluster-local .sqsh paths)
E2E_CPU_CONTAINER_IMAGE=/path/to/jenkins-inbound-agent.sqsh
E2E_GPU_CONTAINER_IMAGE=/path/to/rocm-jenkins.sqsh

# Label expression smoke (configure-smoke.ps1 / run-smoke.ps1) — copy and adjust for your cluster
# E2E_FOLDER=slurm-label-smoke
# E2E_JOB_TEMPLATE_TEST=label-smoke
# SMOKE_PARTITION=defq
# SMOKE_WORKDIR=/tmp/jenkins
# SMOKE_TIME_LIMIT_MINUTES=60
# SMOKE_GPU_TEMPLATE_NAME=smoke-gfx950
# SMOKE_GPU_LABEL=miopen gfx950
# SMOKE_GPU_PARTITION=miopen
# SMOKE_GPU_TRES=gres/gpu:YOUR_GPU_TYPE:1
# SMOKE_GPU_CPUS=4
# SMOKE_GPU_MEMORY_MB=8192
# SMOKE_GPU_NODE_LABEL=gfx950
# SMOKE_JAVA_PATH=java
# SMOKE_DOWNLOAD_AGENT_JAR=true
# Compound label for run-all-pipeline-tests.ps1 template-test job
# SMOKE_NOGPU_LABEL=(your-label-a || your-label-b) && nogpu

# Inline instance-e2e jobs created by run-all-pipeline-tests.ps1
# INSTANCE_E2E_FOLDER=slurm-instance-e2e
# Legacy CK smoke job (optional fifth test in run-all-pipeline-tests.ps1)
# CK_SMOKE_FOLDER=slurm-ck-smoke
# CK_SMOKE_JOB=ck-smoke

# Legato static-node migration smoke — CPU builder with template env vars (see examples/static-node-migration.json)
# LEGATO_FOLDER=slurm-legato-e2e
# LEGATO_JOB=legato-env-smoke
# LEGATO_TEMPLATE_NAME=wl-legato-cpu
# LEGATO_LABEL=legato-compile ubuntu24-therock
# LEGATO_PARTITION=defq
# LEGATO_WORKDIR=/var/jenkins_home
# LEGATO_CPUS=4
# LEGATO_MEMORY_MB=16384
# LEGATO_TIME_LIMIT_MINUTES=60
# LEGATO_JAVA_PATH=java
# LEGATO_DOWNLOAD_AGENT_JAR=true
# LEGATO_ENVIRONMENT_JSON=["CCACHE_MAXSIZE=100G", "NODE_CCACHE_PATH=/your/ccache", "NODE_HAS_CCACHE=1", "NUMBER_OF_EXECUTORS=1"]

# Optional default for probe-slurm-job-status.ps1 when no job id argument is passed
# PROBE_SLURM_JOB_ID=

# Production workload validation (configure-workload-*.ps1 / run-workload.ps1)
WORKLOAD_FOLDER=rocm-libraries-folder
WORKLOAD_JOB=Composable Kernel
WORKLOAD_GIT_URL=https://github.com/ROCm/rocm-libraries.git
WORKLOAD_GIT_BRANCH=develop
# Optional: multibranch branch job suffix for probe-branch-*.ps1 (when branch name differs from WORKLOAD_GIT_BRANCH)
# WORKLOAD_BRANCH_SUFFIX=feature/my-branch
WORKLOAD_JENKINSFILE=projects/composablekernel/Jenkinsfile
WORKLOAD_LIBRARY_NAME=ck
WORKLOAD_LIBRARY_REPO=https://github.com/ROCm/composable_kernel.git
WORKLOAD_LIBRARY_BRANCH=develop
WORKLOAD_LIBRARY_PATH=groovy
WORKLOAD_WORKDIR=/var/jenkins
WORKLOAD_TIME_LIMIT_MINUTES=180
WORKLOAD_JAVA_PATH=java
WORKLOAD_AGENT_JAR=
WORKLOAD_DOWNLOAD_AGENT_JAR=true
WORKLOAD_NOGPU_PARTITION=defq
WORKLOAD_NOGPU_CPUS=4
WORKLOAD_NOGPU_MEMORY_MB=8192
WORKLOAD_GFX942_PARTITION=defq
WORKLOAD_GFX942_TRES=gres/gpu:gfx942-mi300x:1
WORKLOAD_GFX942_CPUS=16
WORKLOAD_GFX942_MEMORY_MB=65536
WORKLOAD_GFX950_PARTITION=miopen
WORKLOAD_GFX950_TRES=gres/gpu:gfx950-mi355x:1
WORKLOAD_GFX950_CPUS=16
WORKLOAD_GFX950_MEMORY_MB=65536
WORKLOAD_GFX90A_PARTITION=defq
WORKLOAD_GFX90A_TRES=gres/gpu:gfx90a:1
WORKLOAD_GFX90A_CPUS=16
WORKLOAD_GFX90A_MEMORY_MB=65536
# Which GPU arch to enable for Phase 5b minimal run (gfx950 often has idle nodes on miopen)
WORKLOAD_BUILD_GFX942=false
WORKLOAD_BUILD_GFX950=true
