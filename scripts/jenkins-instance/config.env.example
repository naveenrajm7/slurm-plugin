# Dedicated Jenkins instance harness — COPY to config.env and fill in your values.
# config.env is gitignored; never commit hostnames, passwords, or tokens.
#
#   cp scripts/jenkins-instance/config.env.example scripts/jenkins-instance/config.env

# Remote host where Docker Jenkins runs (SSH target for deploy scripts)
JENKINS_SSH_HOST=YOUR_USER@YOUR_JENKINS_HOST
JENKINS_SSH_OPTS="-o BatchMode=yes -o ConnectTimeout=10"
JENKINS_REMOTE_DIR=/tmp/jenkins-instance

# Jenkins HTTP (browser + REST scripts on your machine)
JENKINS_HTTP_PORT=8282
JENKINS_HOSTNAME=YOUR_JENKINS_HOST
JENKINS_URL=http://YOUR_JENKINS_HOST:8282

# URL Slurm agents use (direct reachability — no SSH tunnel)
JENKINS_AGENT_URL=http://YOUR_JENKINS_HOST:8282/

JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=CHANGE_ME

# Slurm cluster SSH (for squeue / workdir prep; often same host as JENKINS_SSH_HOST)
SLURM_SSH_HOST=YOUR_USER@YOUR_SLURM_CONTROLLER
SLURM_SSH_OPTS="-o BatchMode=yes -o ConnectTimeout=10"

# Slurm account for scontrol token (optional; defaults to SSH login user)
# SLURM_USER=YOUR_SLURM_USER

# Slurm cloud settings (applied by configure.ps1)
SLURM_CLOUD_NAME=your-slurm-cloud
SLURM_REST_URL=http://YOUR_SLURM_CONTROLLER:6820
SLURM_CREDENTIALS_ID=slurm-jwt-token
# JWT for slurmrestd — set one of:
# SLURM_JWT_TOKEN=eyJ...
# or leave unset to fetch via: scontrol token username=$USER on SLURM_SSH_HOST

# E2E Jenkins jobs (folder/job name without 'job/' prefix)
E2E_FOLDER=slurm-e2e
E2E_JOB_TEMPLATE_TEST=template-test
E2E_JOB_DECLARATIVE_JSON=dec-json-test

# Static cloud template (label + workdir on compute nodes)
E2E_TEMPLATE_LABEL=your-agent-label
E2E_TEMPLATE_PARTITION=cpu
E2E_TEMPLATE_CPUS=16
E2E_TEMPLATE_MEMORY_MB=32768
E2E_TEMPLATE_WORKDIR=/tmp/jenkins
E2E_TIME_LIMIT_MINUTES=55
E2E_RESERVATION=jenkins-e2e

# Container images for declarative JSON tests (cluster-local .sqsh paths)
E2E_CPU_CONTAINER_IMAGE=/path/to/jenkins-inbound-agent.sqsh
E2E_GPU_CONTAINER_IMAGE=/path/to/rocm-jenkins.sqsh
